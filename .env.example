# Copy this file to .env and fill in the values.

# SQLAlchemy async database URL.
# For SQLite (default): sqlite+aiosqlite:////data/slopstudy.db
# For PostgreSQL:       postgresql+asyncpg://user:password@host/dbname
DATABASE_URL=sqlite+aiosqlite:////data/slopstudy.db

# Secret key used for signing JWTs and other cryptographic operations.
# Generate a strong random value for production: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# Comma-separated list of allowed CORS origins. Use * to allow all.
CORS_ORIGINS=*
