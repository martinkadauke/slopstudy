# ---- App ----
# Optional: your SearXNG instance for web-source research (falls back to
# DuckDuckGo/Wikipedia when empty).
SEARXNG_URL=
# Public URL of this instance; used in notification emails.
APP_BASE_URL=http://localhost:8000
# Set to true when serving over HTTPS so session cookies are marked Secure.
COOKIE_SECURE=false
# Comma-separated emails granted admin automatically on login/registration.
# (As a fresh-install fallback, the very first registered user is also an admin.)
ADMIN_EMAILS=

# ---- SMTP (optional — leave SMTP_HOST empty to disable email notifications) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=slopstudy@example.com
# starttls | ssl | none
SMTP_SECURITY=starttls
